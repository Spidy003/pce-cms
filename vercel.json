{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.6.2"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/assets/css/$1" },
    { "src": "/js/(.*)", "dest": "/assets/js/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
